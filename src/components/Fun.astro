---
import SectionLayout from "../layouts/SectionLayout.astro";
import NumberedList from "./NumberedList.astro";

const funList = [
  { title: "Now", slug: "/now" },
  { title: "Studio", slug: "/studio" },
];
---

<SectionLayout id="fun" pageIndex={6} pageTitle="Fun" noContainer>
  <NumberedList list={funList} />
  <!-- <ul class="fun__list">
    <li class="fun__item">
      <span class="fun__number">01</span>
      <a href="/now" class="fun__link">Now</a>
    </li>
    <li class="fun__item">
      <span class="fun__number">02</span>
      <a href="/studio" class="fun__link">The Studio</a>
    </li>
  </ul> -->
</SectionLayout>

<style>
  .fun {
    width: 100%;
  }

  .fun__header {
    border-top: 2px solid currentColor;
    padding-top: var(--space-s);
    margin-bottom: var(--space-xl);
  }

  .fun__label {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
