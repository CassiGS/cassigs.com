---
import SectionLayout from "../layouts/SectionLayout.astro";
---

<SectionLayout id="services" pageIndex={2} pageTitle="Services">
  <ul class="services__list">
    <li class="services__item">
      <span class="services__number">01</span>
      <strong class="services__name">Web Audits</strong>
      <p class="services__text">
        I can help lighthouse web scores and run CMS audits. If you need help
        evaluating something on your marketing website, I can help guide you.
      </p>
    </li>
    <li class="services__item">
      <span class="services__number">02</span>
      <strong class="services__name">Page Builds</strong>
      <p class="services__text">
        From landing pages, specialty pages like ROI calculator, to pricing
        pages. I can take your Figma/design files and help bring them to life.
      </p>
    </li>
    <li class="services__item">
      <span class="services__number">03</span>
      <strong class="services__name">Fractional/Retainer Web Engineer</strong>
      <p class="services__text">
        Need something more on-going? I can sit with your marketing team as an
        honorary teammate and help you with ongoing projects and campaigns. I
        know how to work cross functionally across marketing functions and
        projects.
      </p>
    </li>
  </ul>
</SectionLayout>

<style>
  .services {
    width: 100%;
  }

  .services__container {
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 0 5rem;
  }

  .services__header {
    border-top: 2px solid currentColor;
    padding-top: var(--space-s);
    margin-bottom: var(--space-xl);
  }

  .services__label {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
  }

  .services__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding: var(--space-l);
  }

  .services__item:not(:last-child) {
    border-right: 1px solid currentColor;
  }

  .services__number {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .services__name {
    font-family: var(--font);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
  }

  .services__text {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .services__list {
      grid-template-columns: 1fr;
    }

    .services__item:not(:last-child) {
      border-right: none;
      border-bottom: 1px solid currentColor;
    }
  }
</style>
