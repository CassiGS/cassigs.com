<section class="services" id="services">
  <div class="services__container">
    <div class="services__header">
      <span class="services__label">02 / Services</span>
    </div>
    <ul class="services__list">
      <li class="services__item">
        <span class="services__number">01</span>
        <strong class="services__name">Service</strong>
        <p class="services__text">
          Service description placeholder text goes here.
        </p>
      </li>
      <li class="services__item">
        <span class="services__number">02</span>
        <strong class="services__name">Service</strong>
        <p class="services__text">
          Service description placeholder text goes here.
        </p>
      </li>
      <li class="services__item">
        <span class="services__number">03</span>
        <strong class="services__name">Service</strong>
        <p class="services__text">
          Service description placeholder text goes here.
        </p>
      </li>
    </ul>
  </div>
</section>

<style>
  .services {
    width: 100%;
  }

  .services__container {
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 0 5rem;
  }

  .services__header {
    border-top: 2px solid currentColor;
    padding-top: var(--space-s);
    margin-bottom: var(--space-xl);
  }

  .services__label {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .services__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
  }

  .services__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding: var(--space-l);
  }

  .services__item:not(:last-child) {
    border-right: 1px solid currentColor;
  }

  .services__number {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .services__name {
    font-family: var(--font);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
  }

  .services__text {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .services__list {
      grid-template-columns: 1fr;
    }

    .services__item:not(:last-child) {
      border-right: none;
      border-bottom: 1px solid currentColor;
    }
  }
</style>
