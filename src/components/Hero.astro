<section class="hero">
  <div class="hero__container">
    <h1 class="hero__heading">Cassi<br />Gallagher-Shearer</h1>
    <p class="hero__tagline">
      Marketing Web Engineer for small to mid-sized marketing teams.
      <br />AKA your marketing team's <span>best friend.</span>
    </p>
  </div>
</section>

<style>
  .hero {
    width: 100%;
  }

  .hero__container {
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 5rem 0;
  }

  .hero__heading {
    font-family: var(--font);
    font-size: clamp(3rem, 8vw, 8rem);
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 var(--space-m);
    text-transform: uppercase;
  }

  .hero__tagline {
    font-family: var(--font);
    font-size: clamp(1.5rem, 2vw, 2rem);
    font-weight: 400;
    margin: 0;
    line-height: 1.5;
  }

  .hero__tagline span {
    font-style: italic;
    color: var(--color-accent);
  }
</style>
