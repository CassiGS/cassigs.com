---
const { link, dark, number, text } = Astro.props;
---

{
  link ? (
    <a href={link} class:list={["number-nav", { dark }]}>
      <span>{number}</span>
      <div>{text}</div>
    </a>
  ) : (
    <div class:list={["number-nav", { dark }]}>
      <span>{number}</span>
      <div>{text}</div>
    </div>
  )
}

<style>
  .number-nav {
    border: 1px solid var(--color-border);
    background-color: var(--color-cream);
    color: var(--color-dark);

    display: grid;
    grid-template-columns: 56px 1fr;
    font-size: 14px;
    margin-bottom: -1px;
    text-decoration: none;
    transition: all ease-in-out 0.3s;
    font-weight: 300;

    & span {
      padding: var(--space-s);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 100;
      font-style: italic;
    }

    & div {
      padding: var(--space-s);
      display: flex;
    }
  }

  a.number-nav:hover {
    background-color: var(--color-white);
    border-color: var(--color-white);
  }
</style>
