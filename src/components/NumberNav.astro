---
const { link, dark, number, text } = Astro.props;
const hasToc = Astro.slots.has("default");
---

<div class="number-nav-wrapper">
  {
    link ? (
      <a href={link} class:list={["number-nav", { dark }]}>
        <span>{number}</span>
        <div>{text}</div>
      </a>
    ) : (
      <div class:list={["number-nav", { dark }]}>
        <span>{number}</span>
        <div>{text}</div>
      </div>
    )
  }
  {
    hasToc && (
      <div class="number-nav__toc">
        <slot />
      </div>
    )
  }
</div>

<style>
  .number-nav-wrapper {
    margin-bottom: -1px;
  }

  .number-nav {
    border: 1px solid var(--color-border);
    background-color: var(--color-cream);
    color: var(--color-dark);

    display: grid;
    grid-template-columns: 56px 1fr;
    font-size: 14px;
    text-decoration: none;
    transition: all ease-in-out 0.3s;
    font-weight: 300;

    & span {
      padding: var(--space-s);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 100;
      font-style: italic;
    }

    & div {
      padding: var(--space-s);
      display: flex;
    }
  }

  a.number-nav div:hover {
    text-decoration: underline;
  }

  .number-nav__toc {
    border-right: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    background-color: var(--color-cream);
    color: var(--color-dark);
    font-size: var(--font-size-05);
    padding-left: 56px;
  }
</style>
