---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <span class="site-footer__left">&copy; {year} Cassi Gallagher-Shearer</span>
  <span class="site-footer__right">Built with Astro and Netlify </span>
</footer>

<style>
  footer {
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
  }
  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-m) 0;
    border-top: 1px solid var(--color-border);
    font-family: var(--font);
    font-size: 16px;
    color: var(--color-dark);
    font-weight: 300;
  }
</style>
