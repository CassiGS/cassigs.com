---
import SectionLayout from "../layouts/SectionLayout.astro";

interface Props {
  caseStudies: { title: string; slug: string }[];
}

const { caseStudies } = Astro.props;
---

<SectionLayout id="case-studies" pageIndex={3} pageTitle="Case Studies">
  <ul class="case-studies__list">
    {
      caseStudies.map((study, i) => (
        <a href={study.slug} class="case-studies__link">
          <li class="case-studies__item">
            <span class="case-studies__number">
              {String(i + 1).padStart(2, "0")}
            </span>
            {study.title}
          </li>
        </a>
      ))
    }
  </ul>
</SectionLayout>

<style>
  .case-studies {
    width: 100%;
  }

  .case-studies__container {
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 0 5rem;
  }

  .case-studies__header {
    border-top: 2px solid currentColor;
    padding-top: var(--space-s);
    margin-bottom: var(--space-xl);
  }

  .case-studies__label {
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .case-studies__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .case-studies__item {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    padding: var(--space-m) 0;
    border-top: 1px solid currentColor;
    background-color: transparent;
  }

  .case-studies__item:last-child {
    border-bottom: 1px solid currentColor;
  }

  .case-studies__number {
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.08em;
  }

  .case-studies__link {
    font-family: var(--font);
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    text-decoration: none;
    color: currentColor;
    transition: color 0.15s ease-in-out;
    font-style: none;
  }

  .case-studies__item:hover {
    cursor: pointer;
    background-color: rgba(255, 255, 255, 0.3);
  }

  :global(.case-studies__item:hover .case-studies__link) {
    font-style: italic;
  }

  .case-studies__link:hover,
  .case-studies__link:focus-visible {
    color: var(--color-accent);
  }
</style>
