---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  // { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "mailto:ccgall@gmail.com", label: "Contact", external: true },
];
---

<header class="site-nav">
  <a href="/" class="site-nav__logo">CASSIGS WEB DEVELOPMENT</a>

  <nav class="site-nav__links" aria-label="Main navigation">
    {
      links.map(({ href, label, external }) => (
        <a
          href={href}
          class={`site-nav__link${external ? " site-nav__link--contact" : ""}${!external && (href === "/" ? currentPath === "/" : currentPath.startsWith(href)) ? " site-nav__link--active" : ""}`}
        >
          {label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-s) 0;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-s);
  }

  .site-nav__logo {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-black);
    text-decoration: none;
    letter-spacing: 1px;
  }

  .site-nav__logo:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-l);
  }

  .site-nav__link {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 16px;
    color: var(--color-black);
    text-decoration: none;
    text-transform: uppercase;
    transition: color ease-in-out 0.15s;
  }

  .site-nav__link--active {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-nav__link:not(.site-nav__link--contact):hover,
  .site-nav__link:not(.site-nav__link--contact):focus-visible {
    color: var(--color-accent);
  }

  .site-nav__link:not(.site-nav__link--contact):focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .site-nav__link--contact:focus-visible {
    outline: 2px solid var(--color-black);
    outline-offset: 3px;
  }

  .site-nav__link--contact {
    color: var(--color-white);
    background-color: var(--color-accent);
    padding: 0.4em 0.85em;
    transition: background-color ease-in-out 0.15s;
  }

  .site-nav__link--contact:hover,
  .site-nav__link--contact:focus-visible {
    color: var(--color-white);
    background-color: #b84724;
  }
</style>
