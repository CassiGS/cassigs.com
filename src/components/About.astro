---
import SectionLayout from "../layouts/SectionLayout.astro";
---

<SectionLayout id="about" pageIndex={1} pageTitle="About">
  <div class="about__columns">
    <div class="about__text">
      <p>
        I've spent the last ten years solving problems on the web. I've worn
        many hats in my career — including some stints in design and marketing.
      </p>
      <p>
        As a marketing web developer, I know more than just code. I know the
        <strong>types of problems your team is trying to solve.</strong>
      </p>
      <p>
        From building compelling landing pages, to helping your team
        self-publish with a CMS, to making sure your form captures every lead —
        I'll help your team work faster. <em>No JIRA ticket required.</em>
      </p>
    </div>
    <div class="about__stats">
      <div class="about__stat">
        <span class="about__stat-label">Stat</span>
        <span class="about__stat-number">00</span>
      </div>
      <div class="about__stat">
        <span class="about__stat-label">Stat</span>
        <span class="about__stat-number">00</span>
      </div>
      <div class="about__stat">
        <span class="about__stat-label">Stat</span>
        <span class="about__stat-number">00</span>
      </div>
    </div>
  </div>
</SectionLayout>

<style>
  .about__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .about__text p {
    font-family: var(--font);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    line-height: 1.7;
    margin: 0 0 1rem 0;
  }

  .about__stats {
    display: flex;
    flex-direction: column;
  }

  .about__stat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-s) 0;
    border-top: 1px solid currentColor;
  }

  .about__stat:last-child {
    border-bottom: 1px solid currentColor;
  }

  .about__stat-label {
    font-family: var(--font);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .about__stat-number {
    font-family: var(--font);
    font-size: clamp(1rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .about__columns {
      grid-template-columns: 1fr;
    }
  }
</style>
