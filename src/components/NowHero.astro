<section class="hero">
  <div class="hero__container">
    <h1 class="hero__heading">Now</h1>
    <p class="hero__tagline">
      What am I up to RIGHT NOW? Based on <a href="https://nownownow.com/about"
        >Now Pages</a
      >
    </p>
  </div>
</section>

<style>
  .hero {
    width: 100%;
  }

  .hero__container {
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 5rem 0;
  }

  .hero__heading {
    font-family: var(--font);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 var(--space-m);
    text-transform: uppercase;
  }

  .hero__tagline {
    font-family: var(--font);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    margin: 0;
    line-height: 1.5;
  }

  .hero__tagline span {
    font-style: italic;
    color: var(--color-accent);
  }
</style>
