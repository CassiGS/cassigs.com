---
import "../styles/global.css";
import "../styles/home.css";

import BaseLayout from "../layouts/BaseLayout.astro";
import Tag from "../components/Tag.astro";
import NumberNavList from "../components/NumberNavList.astro";

const postModules = import.meta.glob<{
  frontmatter: { title: string; tags?: string[]; featured?: boolean };
  url: string;
}>("./projects/*.md", { eager: true });

const featuredPosts = Object.values(postModules).filter(
  (p) => p.frontmatter.featured === true,
);

const navItems = [
  { text: "Selected Work" },
  { text: "About", link: "/about" },
  { text: "Contact" },
];
---

<BaseLayout />

