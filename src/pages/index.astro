---
import "../styles/global.css";
import "../styles/home.css";

import BaseLayout from "../layouts/BaseLayout.astro";
import Tag from "../components/Tag.astro";
import NumberNavList from "../components/NumberNavList.astro";

const postModules = import.meta.glob<{
  frontmatter: { title: string; tags?: string[]; featured?: boolean };
  url: string;
}>("./projects/*.md", { eager: true });

const featuredPosts = Object.values(postModules).filter(
  (p) => p.frontmatter.featured === true,
);

const navItems = [
  { text: "Selected Work", link: "#" },
  { text: "About", link: "/about" },
  { text: "Contact", link: "mailto:ccgall@gmail.com" },
];
---

<BaseLayout mainHeading={`Cassi Gallagher-Shearer`} pageIndex="i">
  <p class="hero-home__subhead">
    I'm a web engineer, CMS wrangler, and CSS whisperer based in Bellingham, WA.
    I enjoy solving problems on the web and I'll make friends with your
    marketing team.
  </p>
  <section class="what-i-do">
    <span class="what-i-do__label">What I do</span>
    <div class="what-i-do__columns">
      <div class="what-i-do__column">
        <h3>Frontend Engineering</h3>
        <p>Building fast, accessible interfaces with clean HTML, CSS, and JavaScript that work for real people on real devices.</p>
      </div>
      <div class="what-i-do__column">
        <h3>CMS Integration</h3>
        <p>Wiring up content systems so editors can actually use them — from headless APIs to structured content workflows.</p>
      </div>
      <div class="what-i-do__column">
        <h3>Web Performance</h3>
        <p>Diagnosing what's slow and fixing it. Core Web Vitals, asset optimisation, and keeping load times honest.</p>
      </div>
    </div>
  </section>
  <NumberNavList items={navItems}>
    <Fragment slot="toc-1">
      <div>Coming Soon</div>
      <!-- {featuredPosts.map((post) => (
        <a href={post.url} class="project-container">
          {post.frontmatter.title}
          <div>
            {post.frontmatter.tags?.map((tag) => (
              <Tag dark>{tag}</Tag>
            ))}
          </div>
        </a>
      ))}
      <a href="/projects" class="hero-home__all-projects">
        See all projects →
      </a> -->
    </Fragment>
  </NumberNavList>
</BaseLayout>
