---
import "../styles/global.css";
import "../styles/home.css";

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import KindWords from "../components/KindWords.astro";
import Contact from "../components/Contact.astro";
import Fun from "../components/Fun.astro";
import CaseStudies from "../components/CaseStudies.astro";
import Tag from "../components/Tag.astro";
import NumberNavList from "../components/NumberNavList.astro";

const postModules = import.meta.glob<{
  frontmatter: { title: string; tags?: string[]; featured?: boolean };
  url: string;
}>("./projects/*.md", { eager: true });

const featuredPosts = Object.values(postModules).filter(
  (p) => p.frontmatter.featured === true,
);

const navItems = [
  { text: "Selected Work" },
  { text: "About", link: "/about" },
  { text: "Contact" },
];
---

<BaseLayout>
  <Hero />
  <About />
  <Services />
  <CaseStudies />
  <KindWords />
  <div class="home__more-group">
    <Contact />
    <Fun />
  </div>
</BaseLayout>

<style>
  .home__more-group {
    display: grid;
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 0 5rem;
  }
  @media (min-width: 900px) {
    .home__more-group {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
</style>
