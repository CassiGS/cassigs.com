---
import "../styles/global.css";
import "../styles/home.css";

import BaseLayout from "../layouts/BaseLayout.astro";
import Tag from "../components/Tag.astro";
import NumberNavList from "../components/NumberNavList.astro";

const postModules = import.meta.glob<{
  frontmatter: { title: string; tags?: string[]; featured?: boolean };
  url: string;
}>("./projects/*.md", { eager: true });

const featuredPosts = Object.values(postModules).filter(
  (p) => p.frontmatter.featured === true,
);

const navItems = [
  { text: "Selected Work", link: "#" },
  { text: "About", link: "/about" },
  { text: "Contact", link: "mailto:ccgall@gmail.com" },
];
---

<BaseLayout mainHeading={`Cassi Gallagher-Shearer`} pageIndex="i">
  <div class="hero-home__intro">
    <p class="hero-home__subhead">
      I'm a Frontend Web Engineer based in Bellingham, WA. I build performant
      websites for real humans, I genuinely enjoy writing CSS, and I'll make
      friends with your marketing and content teams.
    </p>
    <div class="hero-home__status">
      <span class="hero-home__status-label">Current Status</span>
      <span class="hero-home__status-text">Available for new projects</span>
    </div>
  </div>
  <section class="what-i-do" aria-labelledby="what-i-do-heading">
    <h2 id="what-i-do-heading" class="what-i-do__label">What I do</h2>
    <div class="what-i-do__columns">
      <div class="what-i-do__column">
        <h3>Frontend Developement</h3>
        <p>
          I build accessible interfaces. Whether I'm working with semantic HTML
          and CSS, or component-based architecture using React, I'm skilled in
          bridging the gap between Figma design and browser.
        </p>
        <div class="what-i-do__tags">
          <span class="what-i-do__tag">HTML</span>
          <span class="what-i-do__tag">CSS</span>
          <span class="what-i-do__tag">JavaScript</span>
          <span class="what-i-do__tag">React</span>
        </div>
      </div>
      <div class="what-i-do__column">
        <h3>CMS Architecture</h3>
        <p>
          I'm skilled in working with CMS-based systems. From connecting
          headless systems to building back-end CMS expiriences your content
          team will enjoy using. I know how CMS architecture works and whatever
          system your team is using, I can get up to speed on quickly.
        </p>
        <div class="what-i-do__tags">
          <span class="what-i-do__tag">Contentful</span>
          <span class="what-i-do__tag">WordPress</span>
          <span class="what-i-do__tag">Headless</span>
        </div>
      </div>
      <div class="what-i-do__column">
        <h3>Web Performance & SEO</h3>
        <p>
          From Core Web Vitals to performant sites, I know how to analyze and
          problem solve lighthouse scores for better, faster websites
        </p>
        <div class="what-i-do__tags">
          <span class="what-i-do__tag">Core Web Vitals</span>
          <span class="what-i-do__tag">Lighthouse</span>
          <span class="what-i-do__tag">Image optimization</span>
        </div>
      </div>
    </div>
  </section>
  <NumberNavList items={navItems}>
    <Fragment slot="toc-1">
      <div>Coming Soon</div>
      <!-- {featuredPosts.map((post) => (
        <a href={post.url} class="project-container">
          {post.frontmatter.title}
          <div>
            {post.frontmatter.tags?.map((tag) => (
              <Tag dark>{tag}</Tag>
            ))}
          </div>
        </a>
      ))}
      <a href="/projects" class="hero-home__all-projects">
        See all projects →
      </a> -->
    </Fragment>
  </NumberNavList>
</BaseLayout>
