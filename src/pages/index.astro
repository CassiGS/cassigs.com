---
import "../styles/global.css";
import "../styles/home.css";

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import KindWords from "../components/KindWords.astro";
import Contact from "../components/Contact.astro";
import Fun from "../components/Fun.astro";
import CaseStudies from "../components/CaseStudies.astro";
import Button from "../components/Button.astro";

const projectModules = import.meta.glob<{
  frontmatter: { title: string };
}>("./projects/*.mdx", { eager: true });

const caseStudies = Object.entries(projectModules).map(([path, mod]) => {
  const slug = path.split("/").pop()?.replace(".mdx", "") ?? "";
  return {
    title: mod.frontmatter.title,
    slug: `/projects/${slug}`,
  };
});

const stats = [
  { label: "Based In", calloutText: "Bellingham, WA" },
  { label: "Org Specialties", calloutText: "B2B, SaaS, Agency" },
  { label: "CMS Specialties", calloutText: "Contentful, Headless" },
  { label: "Tech Stack", calloutText: "React, HTML, CSS, Astro" },
  { label: "Pages Shipped", calloutText: "1000+" },
  { label: "Years Wrangling the Web", calloutText: "10+" },
  { label: "Office Mate", calloutText: "Sleepy", additionalEl: true },
];
---

<BaseLayout pageTitle="CassiGS Marketing Web Engineer & Web Development">
  <Hero />
  <About pageIndex={1} pageTitle="About" listItems={stats}>
    <div class="about__column-text">
      <div>
        <p>
          I've worn a lot of hats in my career. As a frontend developer who came
          up through visual journalism, design, and marketing, I can go beyond
          technical implementation: I know the types of problems your team is
          trying to solve.
        </p>

        <p>
          <strong>For marketing and communications teams:</strong> I've sat directly
          on this side of the house. I can take your Figma/design files and help bring
          them to life: landing pages, specialty pages (e.g., ROI calculators), pricing
          pages, or whatever else you dream up.
        </p>
        <p>
          <strong>For agencies:</strong> I plug into existing projects without slowing
          your team down. I can ramp up on a codebase, work within your process, and
          interface directly with clients when needed. I can act as an extension of
          your team, not a dependency.
        </p>
        <p>
          <strong>For nonprofits and mission-driven organizations:</strong> I understand
          that storytelling is key, and that your team needs a site that is easy to
          use. I can help build solutions for non-technical team members to use easily.
        </p>
      </div>
      <div class="about__buttons">
        <Button
          link="/CGS_Resume2026.pdf"
          linkText="Download Resume"
          type="download"
        />
        <Button
          link="https://www.linkedin.com/in/cassigs/"
          linkText="Connect on LinkedIn"
          type="external"
        />
      </div>
    </div>
  </About>
  <Services />
  <CaseStudies caseStudies={caseStudies} />
  <KindWords />
  <div class="home__more-group">
    <Contact />
    <Fun />
  </div>
</BaseLayout>

<style>
  .home__more-group {
    display: grid;
    width: 90%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 0 5rem;
  }
  @media (min-width: 900px) {
    .home__more-group {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
  .about__buttons {
    display: flex;
    gap: 2rem;
  }

  .about__column-text {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .about__column-text p {
    margin: 0 0 2rem 0;
  }
</style>
