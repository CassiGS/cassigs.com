---
import "../styles/global.css";
import "../styles/about.css";

import SubLayout from "../layouts/SubLayout.astro";
import AboutTabs from "../components/AboutTabs.tsx";
---

<SubLayout mainHeading="About">
  <!-- ── Intro ──────────────────────────────────────────── -->
  <div class="about-intro">
    <div class="about-intro__bio">
      <p>
        Hi, I'm Cassi — a Frontend Engineer based in [City]. I love CSS,
        thoughtful UI, and building experiences that feel good for real humans.
      </p>
      <p>
        I've spent [X] years working across design systems, accessibility, and
        interactive interfaces. When I'm not writing code, you'll find me [hobby
        / interest].
      </p>
    </div>

    <div class="about-intro__photo">
      <!-- Replace src with your actual photo path -->
      <!-- <img src="/your-photo.jpg" alt="Cassi Gallagher-Shearer" /> -->
      <div class="about-intro__photo--placeholder">photo</div>
    </div>
  </div>

  <!-- ── Tabbed Detail Section ──────────────────────────── -->
  <AboutTabs client:load />
</SubLayout>
