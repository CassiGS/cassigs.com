---
import "../styles/global.css";
import "../styles/about.css";

import BaseLayout from "../layouts/BaseLayout.astro";
import NumberNavList from "../components/NumberNavList.astro";
import { Image } from "astro:assets";

import profilePhoto from "../images/profile.jpeg";

const navItems = [
  { text: "Education" },
  { text: "Experience" },
  { text: "Skills" },
  // { text: "Hobbies" },
];
---

<BaseLayout mainHeading="About" pageIndex="ii">
  <!-- ── Intro ──────────────────────────────────────────── -->
  <div class="about-intro">
    <div class="about-intro__bio">
      <p>
        Hi, I'm Cassi. I'm a frontend engineer specializing in marketing
        websites and CMS-driven development.
      </p>
      <p>
        I originally started the journey as a Visual Journalism kid, always with
        a camera in my hand. Somewhere along the way I added technical support
        rep for casual video games, designer for dental facebook sites,
        nonprofit email developer, and a brief stint signing people up for video
        game user testing, to my many hats.
      </p>
      <p>
        Now as a web developer whose spent 10+ years solving problems on the
        web, my throughline has always been approaching every problem with
        empathy and as a communication problem first, a technical one second. I
        especially love working with mission-driven companies.
      </p>
      <p>
        I know it's a cliche to say that you thrive at the intersection of
        something, but LinkedIn jargon aside, my diverse background really does
        mean that I enjoy and thrive at solving problems that bridge the gap
        between design, development, marketing, and user experience.
      </p>
      <p>
        Outside of work I like to spend a lot of time outdoors (on a bike or on
        a mountain, but weirdly - not both), getting crafty with some knitting
        or illustration, or playing a cozy video game.
      </p>
      <!-- <p>
        You can see what craft project I'm working on over at my studio or see
        what I'm up to in general now.
      </p> -->
    </div>

    <div class="about-intro__photo">
      <!-- Replace src with your actual photo path -->
      <!-- <img src="/your-photo.jpg" alt="Cassi Gallagher-Shearer" /> -->
      <Image src={profilePhoto} alt="A photo of Cassi Gallagher-Shearer" />
    </div>
  </div>

  <!-- ── Tabbed Detail Section ──────────────────────────── -->
  <NumberNavList items={navItems}>
    <Fragment slot="toc-1">
      <div class="experience-section">
        <div>
          <h3>School</h3>
          <ul>
            <li>
              2006 - 2010
              <div>
                <h4 class="job-meta">
                  Bachelor of Arts | Visual Journalism - Western Washington
                  University
                </h4>
                Activities: Online Editor: Western Front / Online Editor: Klipsun
                Magazine / Web Development Certificate. Reporter: Western Front &
                Klipsun Magazine. Part of: KVIK Broadcasting Club & NPPA: Western
                Chapter. Visual Journalism Internship at Bellingham Alive!
              </div>
            </li>
          </ul>
        </div>
        <div>
          <div>
            <h3>Certificates</h3>
            <ul>
              <li>
                2016
                <div>
                  <h4 class="job-meta">
                    Full Stack Web Development | Dev Bootcamp
                  </h4>
                  At Dev Bootcamp we focused on Full Stack Web development, utilizing
                  Ruby on Rails for back end development, as well as Javascript and
                  basic front-end technologies such as HTML and CSS. We also covered
                  modern software team workflows such as Agile development and pair
                  programming.
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Fragment>
    <Fragment slot="toc-2" class="experience-section">
      <div class="experience-section">
        <div>
          <h3>Work</h3>
          <ul class="jobs">
            <li>
              Nov 2021 – Nov 2025
              <div>
                <h4 class="job-meta">Marketing Web Engineer — Submittable</h4>
                Maintained and grew a Gatsby + Contentful marketing site, building
                dozens of new page templates from Figma designs — including two homepage
                redesigns, an ROI calculator, and a full blog migration of 300+ posts
                from WordPress. Served as technical lead through a major site rebrand,
                coordinating the migration and consolidation of 1,000+ pages across
                two properties.
              </div>
            </li>
            <li>
              Mar 2019 – Nov 2021
              <div>
                <h4 class="job-meta">
                  Senior Engineer, Web Engineering — Slalom Build
                </h4>
                Transitioned to Slalom Build and consulted across six client projects
                spanning React, WordPress, and Drupal. Managed a diverse portfolio
                of projects including Wordpress template builds, React UI builds,
                Drupal build and site maitanance, and more.
              </div>
            </li>
            <li>
              Nov 2017 – Mar 2019
              <div>
                <h4 class="job-meta">
                  Engineer, Web & Marketing Engineering — Slalom Consulting
                </h4>
                Part of the Digital Experience Management practice, working across
                12+ projects at the intersection of marketing and engineering. Embedded
                with a healthcare client to build a Drupal-based blogging platform
                focused on editor usability, and contributed to a provider research
                portal for end users.
              </div>
            </li>
            <li>
              May 2014 – May 2017
              <div>
                <h4 class="job-meta">
                  Production Artist — Sesame Communications
                </h4>
                Supported a web development and SEO team managing 30+ client cases
                weekly — making HTML/CSS edits to live websites, conducting QA, designing
                social assets, and writing internal documentation to streamline team
                workflows.
              </div>
            </li>
          </ul>
        </div>
        <div>
          <h3>Volunteer</h3>
          <ul>
            <li>
              Jun 2020
              <div>
                <h4 class="job-meta">
                  Volunteer WordPress Developer — Tech For Campaigns
                </h4>
                Built out political campaign websites using a WordPress template,
                contributing web skills toward down-ballot campaigns that don't always
                have access to technical help.
              </div>
            </li>

            <li>
              Jan 2019 – Aug 2021
              <div>
                <h4 class="job-meta">
                  Web Editor & Email Marketer — The World is Fun
                </h4>
                Managed the organization's Squarespace site — updating content, building
                new pages, and keeping things tidy. Previously ran the volunteer newsletter
                for five years: writing copy, managing the list, and leading a migration
                to a modern responsive email platform.
              </div>
            </li>

            <li>
              Jan 2026 – Present
              <div>
                <h4 class="job-meta">Volunteer — Bellingham Food Bank</h4>
                Weekly grocery services support — stocking shelves and helping people
                find what they need.
              </div>
            </li>
          </ul>
        </div>
      </div>
    </Fragment>
    <Fragment slot="toc-3">
      <div class="skills-grid">
        <div class="skills-grid__column">
          <h3>Frontend</h3>
          <ul class="skills-grid__list">
            <li>HTML</li>
            <li>CSS</li>
            <li>JavaScript</li>
            <li>React</li>
            <li>Astro</li>
            <li>Accessibility</li>
          </ul>
        </div>
        <div class="skills-grid__column">
          <h3>CMS</h3>
          <ul class="skills-grid__list">
            <li>Contentful</li>
            <li>WordPress</li>
            <li>Drupal</li>
            <li>Headless architecture</li>
          </ul>
        </div>
        <div class="skills-grid__column">
          <h3>Tooling</h3>
          <ul class="skills-grid__list">
            <li>Git</li>
            <li>Figma</li>
            <li>Gatsby</li>
            <li>Webpack</li>
            <li>Netlify</li>
          </ul>
        </div>
        <div class="skills-grid__column">
          <h3>Other</h3>
          <ul class="skills-grid__list">
            <li>Core Web Vitals</li>
            <li>SEO</li>
            <li>Email development</li>
            <li>Agile / Scrum</li>
            <li>Technical writing</li>
          </ul>
        </div>
      </div>
    </Fragment>
  </NumberNavList>
</BaseLayout>
